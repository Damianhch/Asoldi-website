# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set in Hostinger/env or .env.local (never commit .env.local with real values).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (optional).
APP_URL="MY_APP_URL"

# Optional persistent runtime storage path.
# On Hostinger the app defaults to .builds/data so runtime users/sites/admin data
# survive redeploys. Override only if you want a custom location.
# APP_DATA_DIR=

# Admin CMS (domain.com/admin). Change in production.
# ADMIN_USERNAME=asoldi.com
# ADMIN_PASSWORD=your-secure-password
# ADMIN_SECRET=long-random-string-for-jwt-signing

# For local dev with Vite: run API on port 3001 so Vite can proxy /api.
# PORT=3001

# Firebase: copy firebase-applet-config.example.json to firebase-applet-config.json
# and fill in values from Firebase Console. Do not commit real API keys.

# SMTP for password reset, booking emails (Hostinger or Resend).
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=kontakt@asoldi.com
# SMTP_PASS=
# SMTP_FROM=Asoldi <kontakt@asoldi.com>

# Employee dashboard integrations.
# WordPress sync (imports employee users with employee/ansatt role).
# WORDPRESS_URL=https://asoldi.com
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=

# MyPhoner sync (campaign/list IDs can be comma-separated).
# MYPHONER_API_KEY=
# MYPHONER_SUBDOMAIN=
# MYPHONER_CAMPAIGN_ID=

# Luca Regnskap sync.
# LUCA_API_KEY=
# LUCA_COMPANY_ID=
