{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A booking request from a client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the client."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the client."
        },
        "company": {
          "type": "string",
          "description": "The company name."
        },
        "message": {
          "type": "string",
          "description": "The message or details of the booking."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the booking was created."
        }
      },
      "required": ["name", "email", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": {
        "$ref": "#/entities/Booking"
      },
      "description": "Stores booking requests."
    }
  }
}
